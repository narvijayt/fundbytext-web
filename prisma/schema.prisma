generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
    admin
    user
}

enum CampaignType {
    individual
    organization
}

enum CampaignStatus {
    draft
    upcoming
    active
    completed
}

enum GoalType {
    open_ended       // Individual — auto-scales +20% when met
    fixed            // Individual — stops at target amount
    org_goal         // Organization — one shared target
    participant_goal // Organization — each participant has their own target
}

enum BackgroundTheme {
    logo
    athletic
    sports
    trophy_wall
    geometric
    abstract
}

enum MediaType {
    profile // profile picture / logo
    hero    // main campaign banner image
    gallery // up to 3 extra gallery images
}

enum DonorStatus {
    not_donated
    contacted
    donated
}

enum PaymentMethod {
    card
    paypal
    google_pay
    amex
}

enum PaymentStatus {
    pending
    completed
    failed
    refunded
}

enum NotificationType {
    participant // sent to a specific participant
    campaign    // sent to donors / campaign-wide
}

enum NotificationStatus {
    scheduled
    sent
    failed
}

enum NotificationChannel {
    sms
    email
    both
}

// Campaign member roles:
//   organizer  = the user who created / owns the campaign
//   participant = a fundraising participant added by the organizer
// A single member may hold both roles simultaneously (organizer who also raises funds).
enum MemberRole {
    organizer
    participant
}

// Controls who can reach and find the campaign page:
//   private  = nobody outside the org can access the URL (404)
//   unlisted = accessible via direct link, not shown in marketing pages
//   public   = accessible + listed in marketing/discovery pages
enum CampaignVisibility {
    private
    unlisted
    public
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
    id                     String    @id @default(uuid()) @db.Uuid
    first_name             String    @db.VarChar(100)
    last_name              String    @db.VarChar(100)
    email                  String    @unique @db.VarChar(255)
    phone                  String?   @db.VarChar(20)
    password_hash          String
    profile_photo_url      String?
    // Platform role: admin = full system access | user = standard platform user
    role                   UserRole  @default(user)
    is_suspended           Boolean   @default(false)
    suspension_message     String?   @db.Text
    deleted_at             DateTime? @db.Timestamptz(3)
    deleted_email          String?   @db.VarChar(255) // original email saved on soft-delete
    is_email_verified      Boolean   @default(false)
    is_phone_verified      Boolean   @default(false)
    password_reset_token   String?   @unique @db.VarChar(255)
    password_reset_expires DateTime? @db.Timestamptz(3)
    created_at             DateTime  @default(now()) @db.Timestamptz(3)
    updated_at             DateTime  @updatedAt @db.Timestamptz(3)

    sessions      UserSession[]
    // One org per user — created implicitly on first org-type campaign
    organization  Organization?    @relation("OrgCreatedBy")
    memberships   CampaignMember[]
    donor_account CampaignDonor[]  @relation("DonorUserAccount")

    @@map("users")
}

// ─────────────────────────────────────────────
// USER SESSIONS
// ─────────────────────────────────────────────

model UserSession {
    id          String    @id @default(uuid()) @db.Uuid
    user_id     String    @db.Uuid
    is_mobile   Boolean   @default(false)
    remember_me Boolean   @default(false)
    expires_at  DateTime? @db.Timestamptz(3) // null = never expires (mobile)
    ip_address  String?   @db.VarChar(45)
    user_agent  String?   @db.VarChar(500)
    revoked_at  DateTime? @db.Timestamptz(3) // null = active session
    created_at  DateTime  @default(now()) @db.Timestamptz(3)

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@map("user_sessions")
}

// ─────────────────────────────────────────────
// ORGANIZATIONS
// Created implicitly when a user runs their first "organization" campaign.
// Auto-populated for subsequent org campaigns. No standalone create UI.
// ─────────────────────────────────────────────

model Organization {
    id           String   @id @default(uuid()) @db.Uuid
    created_by   String   @unique @db.Uuid // one org per user
    name         String   @db.VarChar(100)
    logo_url     String?
    invite_token String   @unique @db.VarChar(64) // shareable link token
    created_at   DateTime @default(now()) @db.Timestamptz(3)
    updated_at   DateTime @updatedAt @db.Timestamptz(3)

    creator   User       @relation("OrgCreatedBy", fields: [created_by], references: [id])
    campaigns Campaign[]

    @@map("organizations")
}

// ─────────────────────────────────────────────
// CAMPAIGNS
// Organizer role is stored in campaign_member_roles (role = organizer),
// not as a denormalized created_by. Both roles can coexist for the same user.
// ─────────────────────────────────────────────

model Campaign {
    id                     String          @id @default(uuid()) @db.Uuid
    organization_id        String?         @db.Uuid // null = standalone individual campaign
    campaign_type          CampaignType
    name                   String?         @unique @db.VarChar(50)
    slug                   String          @unique @db.VarChar(100) // auto-generated on creation
    org_display_name       String?         @db.VarChar(100) // free-text display label (public page)
    story                  String?         @db.Text
    start_date             DateTime?       @db.Timestamptz(3)
    end_date               DateTime?       @db.Timestamptz(3)
    status                 CampaignStatus  @default(draft)
    goal_type              GoalType?
    goal_amount            Decimal?        @db.Decimal(10, 2)
    initial_goal_amount    Decimal?        @db.Decimal(10, 2) // locked at first save; goal_amount auto-scales
    total_raised           Decimal         @default(0) @db.Decimal(10, 2)
    donors_per_participant Int?            // Organization campaigns: donors per participant
    background_theme       BackgroundTheme @default(sports)
    accent_color           String?         @db.VarChar(7) // hex e.g. #1565C0 (primary)
    secondary_color        String?         @db.VarChar(7) // hex e.g. #374151 (secondary)
    thank_you_message      String?         @db.Text // max 940 chars
    visibility         CampaignVisibility @default(private)  // access control (see enum)
    donations_enabled           Boolean  @default(true)  // organizer can pause donations independently
    donations_disabled_message  String?  @db.Text         // shown to visitors when donations are paused
    current_step       Int                @default(1)       // wizard resume: 1–5
    created_at             DateTime        @default(now()) @db.Timestamptz(3)
    updated_at             DateTime        @updatedAt @db.Timestamptz(3)

    organization  Organization?          @relation(fields: [organization_id], references: [id])
    media         CampaignMedia[]
    payout        CampaignPayout?
    members       CampaignMember[]
    donors        CampaignDonor[]
    donations     Donation[]
    notifications CampaignNotification[]

    @@map("campaigns")
}

// ─────────────────────────────────────────────
// CAMPAIGN MEDIA  (profile pic, hero, gallery)
// ─────────────────────────────────────────────

model CampaignMedia {
    id          String    @id @default(uuid()) @db.Uuid
    campaign_id String    @db.Uuid
    media_type  MediaType
    url         String
    sort_order  Int       @default(0)
    created_at  DateTime  @default(now()) @db.Timestamptz(3)

    campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

    @@map("campaign_media")
}

// ─────────────────────────────────────────────
// CAMPAIGN PAYOUT  (where to mail the check)
// ─────────────────────────────────────────────

model CampaignPayout {
    id                   String   @id @default(uuid()) @db.Uuid
    campaign_id          String   @unique @db.Uuid
    recipient_first_name String   @db.VarChar(100)
    recipient_last_name  String   @db.VarChar(100)
    org_name             String?  @db.VarChar(100) // required for Organization campaigns
    street_address       String   @db.VarChar(255)
    apt_suite            String?  @db.VarChar(50)
    city                 String   @db.VarChar(100)
    state                String   @db.VarChar(50)
    zip                  String   @db.VarChar(10)
    created_at           DateTime @default(now()) @db.Timestamptz(3)
    updated_at           DateTime @updatedAt @db.Timestamptz(3)

    campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

    @@map("campaign_payout")
}

// ─────────────────────────────────────────────
// CAMPAIGN MEMBERS
// All campaign participants (organizers and/or participants) live here.
// user_id is null while the invite is pending (no account yet).
// first_name/last_name/email are stored for pending invitees; once they
// accept and create an account user_id is set and joined_at is recorded.
// ─────────────────────────────────────────────

model CampaignMember {
    id                String    @id @default(uuid()) @db.Uuid
    campaign_id       String    @db.Uuid
    user_id           String?   @db.Uuid // null = invite pending
    first_name        String    @db.VarChar(100)
    last_name         String    @db.VarChar(100)
    email             String?   @db.VarChar(255)
    phone             String?   @db.VarChar(20)
    profile_photo_url String?
    can_upload_photo  Boolean   @default(false)
    target_donors     Int       @default(20) // participant fundraising target
    invite_token      String?   @unique @db.VarChar(100)
    joined_at         DateTime? @db.Timestamptz(3) // set when invite accepted
    created_at        DateTime  @default(now()) @db.Timestamptz(3)
    updated_at        DateTime  @updatedAt @db.Timestamptz(3)

    campaign              Campaign               @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
    user                  User?                  @relation(fields: [user_id], references: [id])
    roles                 CampaignMemberRole[]
    donors                CampaignDonor[]  @relation("DonorAssignedMember")
    added_donors          CampaignDonor[]  @relation("DonorAddedByMember")
    donations             Donation[]
    received_notifications CampaignNotification[]

    // Unique per campaign on email (supports pending invites where user_id is null)
    @@unique([campaign_id, email])
    @@map("campaign_members")
}

// ─────────────────────────────────────────────
// CAMPAIGN MEMBER ROLES  (junction: member ↔ role)
// A member may hold both organizer and participant roles simultaneously.
// ─────────────────────────────────────────────

model CampaignMemberRole {
    id        String     @id @default(uuid()) @db.Uuid
    member_id String     @db.Uuid
    role      MemberRole

    member CampaignMember @relation(fields: [member_id], references: [id], onDelete: Cascade)

    @@unique([member_id, role])
    @@map("campaign_member_roles")
}

// ─────────────────────────────────────────────
// CAMPAIGN DONORS  (contacts added by members)
// ─────────────────────────────────────────────

model CampaignDonor {
    id                String      @id @default(uuid()) @db.Uuid
    campaign_id        String      @db.Uuid
    assigned_member_id String?    @db.Uuid // which member this donor is assigned to
    added_by_member_id String?    @db.Uuid // who added this donor (organizer or participant)
    user_id            String?    @db.Uuid // linked if donor later creates an account
    first_name        String      @db.VarChar(100)
    last_name         String      @db.VarChar(100)
    email             String?     @db.VarChar(255)
    phone             String?     @db.VarChar(20)
    email_valid       Boolean     @default(true)
    status            DonorStatus @default(not_donated)
    invite_token      String?     @unique @db.VarChar(100)
    short_code        String?     @unique @db.VarChar(8)
    last_contacted_at DateTime?   @db.Timestamptz(3)
    created_at        DateTime    @default(now()) @db.Timestamptz(3)
    updated_at        DateTime    @updatedAt @db.Timestamptz(3)

    campaign         Campaign        @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
    assigned_member  CampaignMember? @relation("DonorAssignedMember", fields: [assigned_member_id], references: [id])
    added_by_member  CampaignMember? @relation("DonorAddedByMember", fields: [added_by_member_id], references: [id])
    user             User?           @relation("DonorUserAccount", fields: [user_id], references: [id])
    donations        Donation[]

    @@map("campaign_donors")
}

// ─────────────────────────────────────────────
// DONATIONS  (actual payment records)
// ─────────────────────────────────────────────

model Donation {
    id                       String        @id @default(uuid()) @db.Uuid
    campaign_id              String        @db.Uuid
    campaign_donor_id        String?       @db.Uuid // pre-added donor contact, if matched
    member_id                String?       @db.Uuid // attributed participant
    amount                   Decimal       @db.Decimal(10, 2)
    platform_fee             Decimal       @db.Decimal(10, 2) // 10% of amount
    net_amount               Decimal       @db.Decimal(10, 2) // amount - platform_fee
    donor_first_name         String        @db.VarChar(100)
    donor_last_name          String        @db.VarChar(100)
    donor_display_name       String?       @db.VarChar(255) // "Anonymous" or real name for public feed
    donor_email              String?       @db.VarChar(255)
    donor_phone              String?       @db.VarChar(20)
    donor_country            String?       @db.VarChar(100)
    donor_zip                String?       @db.VarChar(10)
    is_anonymous             Boolean       @default(false)
    stripe_payment_intent_id String?       @unique @db.VarChar(255)
    payment_method           PaymentMethod @default(card)
    payment_status           PaymentStatus @default(pending)
    card_brand               String?       @db.VarChar(50)   // e.g. "visa", "mastercard"
    card_last4               String?       @db.VarChar(4)
    card_exp_month           Int?
    card_exp_year            Int?
    is_flagged               Boolean       @default(false)
    flag_note                String?       @db.Text
    created_at               DateTime      @default(now()) @db.Timestamptz(3)

    campaign       Campaign        @relation(fields: [campaign_id], references: [id])
    campaign_donor CampaignDonor?  @relation(fields: [campaign_donor_id], references: [id])
    member         CampaignMember? @relation(fields: [member_id], references: [id])

    @@map("donations")
}

// ─────────────────────────────────────────────
// CAMPAIGN NOTIFICATIONS  (auto-triggered SMS + Email)
// ─────────────────────────────────────────────

model CampaignNotification {
    id                  String              @id @default(uuid()) @db.Uuid
    campaign_id         String              @db.Uuid
    recipient_member_id String?             @db.Uuid // null = campaign-wide broadcast
    notification_type   NotificationType
    trigger_event       String              @db.VarChar(100) // e.g. "signup", "halfway", "goal_hit"
    message             String              @db.Text
    helper_text         String?             @db.Text
    channel             NotificationChannel @default(both)
    scheduled_at        DateTime?           @db.Timestamptz(3)
    sent_at             DateTime?           @db.Timestamptz(3)
    status              NotificationStatus  @default(scheduled)
    created_at          DateTime            @default(now()) @db.Timestamptz(3)

    campaign         Campaign        @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
    recipient_member CampaignMember? @relation(fields: [recipient_member_id], references: [id])

    @@map("campaign_notifications")
}
